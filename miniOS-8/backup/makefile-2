NASM = nasm
CC = gcc
LD = ld

CFLAGS = -m32 -c -ffreestanding -nostdlib -fno-builtin -fno-pic
LDFLAGS = -m elf_i386 -Ttext 0x8200 -e kernel_main --oformat binary

TARGET = os_image.bin

all: $(TARGET)

# 부트(1섹터) + 섹터2(1섹터) + C커널(3섹터 이후)을 물리적으로 결합
$(TARGET): boot.bin sector2.bin kernel.bin
	cat boot.bin sector2.bin kernel.bin > $(TARGET)

boot.bin: boot.asm
	$(NASM) -f bin boot.asm -o boot.bin

# ★ sector2를 elf32가 아닌 어제처럼 순수 바이너리(-f bin)로 컴파일합니다!
sector2.bin: sector2.asm
	$(NASM) -f bin sector2.asm -o sector2.bin

# 순수 C언어 커널 빌드
kernel.bin: kernel.o
	$(LD) $(LDFLAGS) kernel.o -o kernel.bin

kernel.o: kernel.c
	$(CC) $(CFLAGS) kernel.c -o kernel.o

clean:
	rm -f *.bin *.o $(TARGET)

run: $(TARGET)
	qemu-system-x86_64 -drive format=raw,file=$(TARGET)
